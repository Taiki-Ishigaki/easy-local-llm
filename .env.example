# Routed model alias used by the Python client
LITELLM_MODEL_NAME=local-phi3
LITELLM_DEFAULT_MODEL=local-phi3
LITELLM_TIMEOUT_SECONDS=180

# Optional JSON file for registering multiple models with LiteLLM
# LITELLM_MODEL_CONFIG_FILE=config/models.json

# Provider to route through LiteLLM: ollama, openai_oss, openai, gemini
LITELLM_PROVIDER=ollama

# Ollama settings
OLLAMA_MODEL=phi3
OLLAMA_API_BASE=http://host.docker.internal:11434

# OpenAI OSS on Ollama
OPENAI_OSS_MODEL=gpt-oss:20b

# OpenAI settings
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Gemini settings
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
